<?xml version="1.0" encoding="UTF-8"?>
<w:document xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main" xmlns:m="http://schemas.openxmlformats.org/officeDocument/2006/math" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w10="urn:schemas-microsoft-com:office:word" xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture" xmlns:wp="http://schemas.openxmlformats.org/drawingml/2006/wordprocessingDrawing">
<w:body>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">Создай полноценный современный сайт для полиграфического центра</w:t></w:r><w:r><w:t xml:space="preserve"> </w:t></w:r><w:r><w:rPr><w:b /><w:bCs /></w:rPr><w:t xml:space="preserve">Azamat Print</w:t></w:r><w:r><w:t xml:space="preserve">.</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="BodyText" /></w:pPr><w:r><w:t xml:space="preserve">Сайт должен быть полностью на</w:t></w:r><w:r><w:t xml:space="preserve"> </w:t></w:r><w:r><w:rPr><w:b /><w:bCs /></w:rPr><w:t xml:space="preserve">қазақ тілінде</w:t></w:r><w:r><w:t xml:space="preserve">, грамотно, без орфографических ошибок.</w:t></w:r></w:p>
    <w:p><w:r><w:pict><v:rect style="width:0;height:1.5pt" o:hralign="center" o:hrstd="t" o:hr="t" /></w:pict></w:r></w:p>
    <w:bookmarkStart w:id="20" w:name="общая-концепция-сайта" />
    <w:p><w:pPr><w:pStyle w:val="Heading2" /></w:pPr><w:r><w:t xml:space="preserve">1. Общая концепция сайта</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">Сайт предназначен для презентации услуг полиграфического центра</w:t></w:r><w:r><w:t xml:space="preserve"> </w:t></w:r><w:r><w:rPr><w:b /><w:bCs /></w:rPr><w:t xml:space="preserve">Azamat Print</w:t></w:r><w:r><w:t xml:space="preserve">, просмотра прайслиста, отзывов и контактной информации.</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="BodyText" /></w:pPr><w:r><w:t xml:space="preserve">На сайте</w:t></w:r><w:r><w:t xml:space="preserve"> </w:t></w:r><w:r><w:rPr><w:b /><w:bCs /></w:rPr><w:t xml:space="preserve">не должно быть возможности оформлять заказы онлайн</w:t></w:r><w:r><w:t xml:space="preserve">.</w:t></w:r><w:r><w:br /></w:r><w:r><w:t xml:space="preserve">Клиенты могут только:</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1001" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">смотреть услуги;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1001" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">смотреть цены;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1001" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">читать отзывы;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1001" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">переходить в социальные сети;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1001" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">звонить;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1001" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">писать в WhatsApp, Instagram или Telegram;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1001" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">открывать адрес в 2GIS.</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">Авторизация должна быть</w:t></w:r><w:r><w:t xml:space="preserve"> </w:t></w:r><w:r><w:rPr><w:b /><w:bCs /></w:rPr><w:t xml:space="preserve">только для сотрудников и администраторов</w:t></w:r><w:r><w:t xml:space="preserve">.</w:t></w:r><w:r><w:br /></w:r><w:r><w:t xml:space="preserve">Она нужна исключительно для изменения цен, редактирования услуг, прайслиста, отзывов и контактной информации.</w:t></w:r></w:p>
    <w:p><w:r><w:pict><v:rect style="width:0;height:1.5pt" o:hralign="center" o:hrstd="t" o:hr="t" /></w:pict></w:r></w:p>
    <w:bookmarkEnd w:id="20" />
    <w:bookmarkStart w:id="21" w:name="дизайн-сайта" />
    <w:p><w:pPr><w:pStyle w:val="Heading2" /></w:pPr><w:r><w:t xml:space="preserve">2. Дизайн сайта</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">Дизайн должен быть:</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1002" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">минималистичным;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1002" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">современным;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1002" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">аккуратным;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1002" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">хорошо анимированным;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1002" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">удобным для телефона и компьютера;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1002" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">адаптивным;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1002" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">подходящим под логотип</w:t></w:r><w:r><w:t xml:space="preserve"> </w:t></w:r><w:r><w:rPr><w:b /><w:bCs /></w:rPr><w:t xml:space="preserve">Azamat Print</w:t></w:r><w:r><w:t xml:space="preserve">.</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">Логотип прикрепляется отдельно сверху.</w:t></w:r><w:r><w:br /></w:r><w:r><w:t xml:space="preserve">Использовать логотип как есть, без фона, в круглой форме.</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="BodyText" /></w:pPr><w:r><w:t xml:space="preserve">Шрифт во всём сайте строго:</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1003" /></w:numPr></w:pPr><w:r><w:rPr><w:b /><w:bCs /></w:rPr><w:t xml:space="preserve">Times New Roman Bold Italic</w:t></w:r><w:r><w:t xml:space="preserve"> </w:t></w:r><w:r><w:t xml:space="preserve">— для заголовков, названий разделов, кнопок и важных элементов;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1003" /></w:numPr></w:pPr><w:r><w:rPr><w:b /><w:bCs /></w:rPr><w:t xml:space="preserve">Times New Roman Italic</w:t></w:r><w:r><w:t xml:space="preserve"> </w:t></w:r><w:r><w:t xml:space="preserve">— для описаний, карточек, текстов услуг и второстепенной информации.</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">Анимации:</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1004" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">плавное появление блоков;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1004" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">мягкое раскрытие категорий услуг;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1004" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">плавные переходы между разделами;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1004" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">анимация кнопок при наведении и нажатии;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1004" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">лёгкая анимация карточек;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1004" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">аккуратная анимация логотипа на главном экране.</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">Дизайн не должен быть перегруженным.</w:t></w:r><w:r><w:br /></w:r><w:r><w:t xml:space="preserve">Главный стиль:</w:t></w:r><w:r><w:t xml:space="preserve"> </w:t></w:r><w:r><w:rPr><w:b /><w:bCs /></w:rPr><w:t xml:space="preserve">тазалық, ыңғайлылық, заманауи минимализм</w:t></w:r><w:r><w:t xml:space="preserve">.</w:t></w:r></w:p>
    <w:p><w:r><w:pict><v:rect style="width:0;height:1.5pt" o:hralign="center" o:hrstd="t" o:hr="t" /></w:pict></w:r></w:p>
    <w:bookmarkEnd w:id="21" />
    <w:bookmarkStart w:id="22" w:name="структура-сайта" />
    <w:p><w:pPr><w:pStyle w:val="Heading2" /></w:pPr><w:r><w:t xml:space="preserve">3. Структура сайта</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">Создай сайт с такими основными разделами:</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1005" /></w:numPr></w:pPr><w:r><w:rPr><w:b /><w:bCs /></w:rPr><w:t xml:space="preserve">Басты бет</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1005" /></w:numPr></w:pPr><w:r><w:rPr><w:b /><w:bCs /></w:rPr><w:t xml:space="preserve">Қызметтер</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1005" /></w:numPr></w:pPr><w:r><w:rPr><w:b /><w:bCs /></w:rPr><w:t xml:space="preserve">Прайс-парақ</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1005" /></w:numPr></w:pPr><w:r><w:rPr><w:b /><w:bCs /></w:rPr><w:t xml:space="preserve">Пікірлер</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1005" /></w:numPr></w:pPr><w:r><w:rPr><w:b /><w:bCs /></w:rPr><w:t xml:space="preserve">Байланыс</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1005" /></w:numPr></w:pPr><w:r><w:rPr><w:b /><w:bCs /></w:rPr><w:t xml:space="preserve">Қызметкерге кіру</w:t></w:r></w:p>
    <w:p><w:r><w:pict><v:rect style="width:0;height:1.5pt" o:hralign="center" o:hrstd="t" o:hr="t" /></w:pict></w:r></w:p>
    <w:bookmarkEnd w:id="22" />
    <w:bookmarkStart w:id="23" w:name="главный-экран" />
    <w:p><w:pPr><w:pStyle w:val="Heading2" /></w:pPr><w:r><w:t xml:space="preserve">4. Главный экран</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">На главном экране разместить:</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1006" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">логотип Azamat Print в круглой форме;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1006" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">название бренда:</w:t></w:r><w:r><w:t xml:space="preserve"> </w:t></w:r><w:r><w:rPr><w:b /><w:bCs /></w:rPr><w:t xml:space="preserve">Azamat Print</w:t></w:r><w:r><w:t xml:space="preserve">;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1006" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">краткое описание под логотипом;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1006" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">кнопки перехода к основным разделам.</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">Текст под логотипом:</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="BodyText" /></w:pPr><w:r><w:rPr><w:b /><w:bCs /></w:rPr><w:t xml:space="preserve">Azamat Print — сапалы баспа, жарқын дизайн және заманауи полиграфиялық қызметтер орталығы. Біз әрбір жұмысты ұқыптылықпен, жауапкершілікпен және шығармашылық көзқараспен орындаймыз.</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="BodyText" /></w:pPr><w:r><w:t xml:space="preserve">Кнопки:</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1007" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">Қызметтер</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1007" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">Прайс-парақ</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1007" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">Пікірлер</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1007" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">Байланыс</w:t></w:r></w:p>
    <w:p><w:r><w:pict><v:rect style="width:0;height:1.5pt" o:hralign="center" o:hrstd="t" o:hr="t" /></w:pict></w:r></w:p>
    <w:bookmarkEnd w:id="23" />
    <w:bookmarkStart w:id="35" w:name="раздел-услуг" />
    <w:p><w:pPr><w:pStyle w:val="Heading2" /></w:pPr><w:r><w:t xml:space="preserve">5. Раздел услуг</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">Создай раздел</w:t></w:r><w:r><w:t xml:space="preserve"> </w:t></w:r><w:r><w:rPr><w:b /><w:bCs /></w:rPr><w:t xml:space="preserve">Қызметтер</w:t></w:r><w:r><w:t xml:space="preserve">.</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="BodyText" /></w:pPr><w:r><w:t xml:space="preserve">Все услуги нужно разделить на группы.</w:t></w:r><w:r><w:br /></w:r><w:r><w:t xml:space="preserve">Каждая группа должна быть в виде кнопки-аккордеона:</w:t></w:r><w:r><w:br /></w:r><w:r><w:t xml:space="preserve">при нажатии открывается описание услуги, при повторном нажатии закрывается.</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="BodyText" /></w:pPr><w:r><w:t xml:space="preserve">Группы услуг:</w:t></w:r></w:p>
    <w:bookmarkStart w:id="24" w:name="баспа-қызметтері" />
    <w:p><w:pPr><w:pStyle w:val="Heading3" /></w:pPr><w:r><w:t xml:space="preserve">Баспа қызметтері</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">Қағаздарды А6 форматынан А0 форматына дейін түрлі тығыздықтағы қағаздарға басып шығару.</w:t></w:r><w:r><w:br /></w:r><w:r><w:t xml:space="preserve">Қағаз тығыздығы: 80 г/м²-ден 230 г/м²-ге дейін.</w:t></w:r><w:r><w:br /></w:r><w:r><w:t xml:space="preserve">Түрлері: түрлі-түсті және ақ-қара баспа.</w:t></w:r></w:p>
    <w:bookmarkEnd w:id="24" />
    <w:bookmarkStart w:id="25" w:name="лазерлік-гравировка" />
    <w:p><w:pPr><w:pStyle w:val="Heading3" /></w:pPr><w:r><w:t xml:space="preserve">Лазерлік гравировка</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">Фанераға, ағашқа, пластикке және органикалық шыныға лазер арқылы кескін түсіру, ою-өрнек салу, жазу жазу, кесу және басып шығару.</w:t></w:r></w:p>
    <w:bookmarkEnd w:id="25" />
    <w:bookmarkStart w:id="26" w:name="ультракүлгін-ук-басып-шығару" />
    <w:p><w:pPr><w:pStyle w:val="Heading3" /></w:pPr><w:r><w:t xml:space="preserve">Ультракүлгін /УК/ басып шығару</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">Кез келген қатты әрі тегіс материал бетіне УК технологиясы арқылы сурет салу, жазу жазу және кескін түсіру.</w:t></w:r></w:p>
    <w:bookmarkEnd w:id="26" />
    <w:bookmarkStart w:id="27" w:name="сублимациялық-басып-шығару" />
    <w:p><w:pPr><w:pStyle w:val="Heading3" /></w:pPr><w:r><w:t xml:space="preserve">Сублимациялық басып шығару</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">Футболкаға, бейсболкаға, саптыаяққа және басқа да бұйымдарға сурет, жазу немесе логотип басу.</w:t></w:r></w:p>
    <w:bookmarkEnd w:id="27" />
    <w:bookmarkStart w:id="28" w:name="кәдесыйлар-әзірлеу" />
    <w:p><w:pPr><w:pStyle w:val="Heading3" /></w:pPr><w:r><w:t xml:space="preserve">Кәдесыйлар әзірлеу</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">Фанерадан, ағаштан, пластиктен және органикалық шыныдан түрлі кәдесый бұйымдарын дайындау:</w:t></w:r><w:r><w:br /></w:r><w:r><w:t xml:space="preserve">«Жеті ата», қоржын, қобдиша, ақшасалғыш, естелік бұйымдар, тойтабақтар, табличкалар, бейдждер, түрлі формадағы мүсіндер, медаль ілгіштер және басқа да бұйымдар.</w:t></w:r></w:p>
    <w:bookmarkEnd w:id="28" />
    <w:bookmarkStart w:id="29" w:name="атаулы-бұйымдар-әзірлеу" />
    <w:p><w:pPr><w:pStyle w:val="Heading3" /></w:pPr><w:r><w:t xml:space="preserve">Атаулы бұйымдар әзірлеу</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">Атаулы және жеке тапсырыспен жасалатын бұйымдарды дайындау:</w:t></w:r><w:r><w:br /></w:r><w:r><w:t xml:space="preserve">блокноттар, қаламсаптар, салпыншақтар, саптыаяқтар, топперлер және басқа да сыйлықтық өнімдер.</w:t></w:r></w:p>
    <w:bookmarkEnd w:id="29" />
    <w:bookmarkStart w:id="30" w:name="фотографиялық-қызметтер" />
    <w:p><w:pPr><w:pStyle w:val="Heading3" /></w:pPr><w:r><w:t xml:space="preserve">Фотографиялық қызметтер</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">Суретке түсіру, дайын суреттерді өңдеу, 3×4, A3, A4, A5, A6 форматтарында фотосурет шығару, фотоальбомдар мен коллаждар әзірлеу, слайд-көрсетілім дайындау.</w:t></w:r></w:p>
    <w:bookmarkEnd w:id="30" />
    <w:bookmarkStart w:id="31" w:name="видеографиялық-қызметтер" />
    <w:p><w:pPr><w:pStyle w:val="Heading3" /></w:pPr><w:r><w:t xml:space="preserve">Видеографиялық қызметтер</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">Видеоматериалдарды өңдеу және монтаждау, қысқаша бейнероликтер, видеоашақырулар, видеоқұттықтаулар және еске алу роликтерін дайындау.</w:t></w:r></w:p>
    <w:bookmarkEnd w:id="31" />
    <w:bookmarkStart w:id="32" w:name="полиграфиялық-қызметтер" />
    <w:p><w:pPr><w:pStyle w:val="Heading3" /></w:pPr><w:r><w:t xml:space="preserve">Полиграфиялық қызметтер</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">Құжаттарды жазу, теру, өңдеу және басып шығару.</w:t></w:r><w:r><w:br /></w:r><w:r><w:t xml:space="preserve">Плакаттар, марапат қағаздары, брошюралар, үнпарақтар, афишалар, буклеттер, ашықхаттар, күнтізбелер, дәмхана мәзірлері, ақпараттық тақталар, табличкалар, бейдждер, визиткалар, каталогтар, портфолиолар және басқа да полиграфиялық өнімдерді әзірлеу.</w:t></w:r><w:r><w:br /></w:r><w:r><w:t xml:space="preserve">Қосымша қызметтер: ламинаттау және түптеу.</w:t></w:r></w:p>
    <w:bookmarkEnd w:id="32" />
    <w:bookmarkStart w:id="33" w:name="электрондық-қызметтер" />
    <w:p><w:pPr><w:pStyle w:val="Heading3" /></w:pPr><w:r><w:t xml:space="preserve">Электрондық қызметтер</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">EGOV.KZ порталы арқылы мемлекеттік қызметтер алу, арнайы органдарға құжат тапсыру, салық декларацияларын тапсыру, үй және жер кезегіне қою, жеке кәсіпкерлерге арналған құжаттарды әзірлеу және кезеңдік есептерді тапсыру.</w:t></w:r></w:p>
    <w:bookmarkEnd w:id="33" />
    <w:bookmarkStart w:id="34" w:name="компьютерлік-қызметтер" />
    <w:p><w:pPr><w:pStyle w:val="Heading3" /></w:pPr><w:r><w:t xml:space="preserve">Компьютерлік қызметтер</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">Компьютерге операциялық жүйе орнату, қосымша бағдарламалар орнату, вирустардан тазалау және шағын жөндеу жұмыстарын жүргізу.</w:t></w:r></w:p>
    <w:p><w:r><w:pict><v:rect style="width:0;height:1.5pt" o:hralign="center" o:hrstd="t" o:hr="t" /></w:pict></w:r></w:p>
    <w:bookmarkEnd w:id="34" />
    <w:bookmarkEnd w:id="35" />
    <w:bookmarkStart w:id="36" w:name="раздел-прайслиста" />
    <w:p><w:pPr><w:pStyle w:val="Heading2" /></w:pPr><w:r><w:t xml:space="preserve">6. Раздел прайслиста</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">Создай отдельный раздел</w:t></w:r><w:r><w:t xml:space="preserve"> </w:t></w:r><w:r><w:rPr><w:b /><w:bCs /></w:rPr><w:t xml:space="preserve">Прайс-парақ</w:t></w:r><w:r><w:t xml:space="preserve">.</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="BodyText" /></w:pPr><w:r><w:t xml:space="preserve">Для клиентов этот раздел должен быть доступен только для просмотра.</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="BodyText" /></w:pPr><w:r><w:t xml:space="preserve">В прайслисте должны быть:</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1008" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">атауы;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1008" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">санаты;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1008" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">қысқаша сипаттамасы;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1008" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">бағасы;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1008" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">орындалу мерзімі;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1008" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">белгісі: «Танымал», «Жеңілдік бар», «Жаңа қызмет» при необходимости.</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">Функции для посетителей:</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1009" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">просмотр цен;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1009" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">поиск услуги по названию;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1009" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">фильтр по категориям;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1009" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">сортировка по цене;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1009" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">просмотр популярных услуг.</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">Важно:</w:t></w:r><w:r><w:br /></w:r><w:r><w:t xml:space="preserve">На сайте не должно быть кнопки</w:t></w:r><w:r><w:t xml:space="preserve"> </w:t></w:r><w:r><w:rPr><w:b /><w:bCs /></w:rPr><w:t xml:space="preserve">«Тапсырыс беру»</w:t></w:r><w:r><w:t xml:space="preserve">.</w:t></w:r><w:r><w:br /></w:r><w:r><w:t xml:space="preserve">Вместо этого у каждой услуги можно добавить кнопку:</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="BodyText" /></w:pPr><w:r><w:rPr><w:b /><w:bCs /></w:rPr><w:t xml:space="preserve">Байланысу</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="BodyText" /></w:pPr><w:r><w:t xml:space="preserve">При нажатии на кнопку</w:t></w:r><w:r><w:t xml:space="preserve"> </w:t></w:r><w:r><w:rPr><w:b /><w:bCs /></w:rPr><w:t xml:space="preserve">Байланысу</w:t></w:r><w:r><w:t xml:space="preserve"> </w:t></w:r><w:r><w:t xml:space="preserve">пользователь должен перейти в WhatsApp-чат организации.</w:t></w:r></w:p>
    <w:p><w:r><w:pict><v:rect style="width:0;height:1.5pt" o:hralign="center" o:hrstd="t" o:hr="t" /></w:pict></w:r></w:p>
    <w:bookmarkEnd w:id="36" />
    <w:bookmarkStart w:id="37" w:name="авторизация-сотрудников" />
    <w:p><w:pPr><w:pStyle w:val="Heading2" /></w:pPr><w:r><w:t xml:space="preserve">7. Авторизация сотрудников</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">Создай отдельный вход</w:t></w:r><w:r><w:t xml:space="preserve"> </w:t></w:r><w:r><w:rPr><w:b /><w:bCs /></w:rPr><w:t xml:space="preserve">Қызметкерге кіру</w:t></w:r><w:r><w:t xml:space="preserve">.</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="BodyText" /></w:pPr><w:r><w:t xml:space="preserve">Авторизация должна быть только для:</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1010" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">сотрудников;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1010" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">администраторов.</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">Клиентская регистрация не нужна.</w:t></w:r><w:r><w:br /></w:r><w:r><w:t xml:space="preserve">Клиентский личный кабинет не нужен.</w:t></w:r><w:r><w:br /></w:r><w:r><w:t xml:space="preserve">Бонусная система не нужна.</w:t></w:r><w:r><w:br /></w:r><w:r><w:t xml:space="preserve">Онлайн-заказы не нужны.</w:t></w:r></w:p>
    <w:p><w:r><w:pict><v:rect style="width:0;height:1.5pt" o:hralign="center" o:hrstd="t" o:hr="t" /></w:pict></w:r></w:p>
    <w:bookmarkEnd w:id="37" />
    <w:bookmarkStart w:id="38" w:name="кабинет-сотрудника" />
    <w:p><w:pPr><w:pStyle w:val="Heading2" /></w:pPr><w:r><w:t xml:space="preserve">8. Кабинет сотрудника</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">После входа сотрудник должен попасть в закрытую панель.</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="BodyText" /></w:pPr><w:r><w:t xml:space="preserve">Возможности сотрудника:</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1011" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">просматривать прайслист;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1011" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">изменять цены услуг;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1011" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">изменять срок выполнения услуги;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1011" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">отмечать услугу как «Танымал»;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1011" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">добавлять скидку;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1011" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">временно скрывать услугу;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1011" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">редактировать краткое описание услуги.</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">Сотрудник не должен иметь доступ к удалению важных данных, если он не администратор.</w:t></w:r></w:p>
    <w:p><w:r><w:pict><v:rect style="width:0;height:1.5pt" o:hralign="center" o:hrstd="t" o:hr="t" /></w:pict></w:r></w:p>
    <w:bookmarkEnd w:id="38" />
    <w:bookmarkStart w:id="39" w:name="административная-панель" />
    <w:p><w:pPr><w:pStyle w:val="Heading2" /></w:pPr><w:r><w:t xml:space="preserve">9. Административная панель</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="FirstParagraph" /></w:pPr><w:r><w:t xml:space="preserve">Администратор должен иметь расширенные права.</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="BodyText" /></w:pPr><w:r><w:t xml:space="preserve">Возможности администратора:</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1012" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">добавлять новые услуги;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1012" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">редактировать услуги;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="Compact" /><w:numPr><w:ilvl w:val="0" /><w:numId w:val="1012" /></w:numPr></w:pPr><w:r><w:t xml:space="preserve">удалять услуги;</w:t></w:r></w:p>
